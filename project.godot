config_version=5

[application]

config/name="Godot Starting Line"
config/version="0.0.1"
run/main_scene="uid://b06rcr3verx4p"
config/features=PackedStringArray("4.6", "GL Compatibility")
boot_splash/bg_color=Color(0.0627451, 0.0627451, 0.0627451, 1)
boot_splash/image="uid://bc7xqaxju4ruo"
config/icon="uid://bpeanp8vanedl"

[autoload]

GameManager="*res://scripts/game_manager.gd"
Flow="*res://addons/flow/editor/autoload.tscn"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/mode=2
window/size/sharp_corners=true
window/stretch/mode="viewport"
display_server/driver.linuxbsd="wayland"

[editor_plugins]

enabled=PackedStringArray("res://addons/flow/plugin.cfg")

